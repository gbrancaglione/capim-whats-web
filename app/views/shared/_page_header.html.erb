<%# locals: (title:, subtitle: nil, back_path: nil, back_label: nil) -%>
<header class="flex items-start justify-between gap-3">
  <div class="flex flex-col gap-1">
    <% if local_assigns[:back_path] %>
      <%= link_to back_path,
                  class: "inline-flex w-fit items-center gap-1 text-xs font-medium text-neutral-medium no-underline transition hover:text-brand-primary" do %>
        <svg viewBox="0 0 24 24" class="h-3.5 w-3.5"><path d="M15 6l-6 6 6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <%= local_assigns[:back_label] || "Voltar" %>
      <% end %>
    <% end %>
    <h1 class="m-0 font-heading text-2xl font-bold text-neutral-darkest"><%= title %></h1>
    <% if local_assigns[:subtitle] %>
      <p class="m-0 text-sm text-neutral-medium"><%= subtitle %></p>
    <% end %>
  </div>
  <% if block_given? %>
    <div class="flex flex-none items-center gap-2"><%= yield %></div>
  <% end %>
</header>
