<%# locals: (row:, selected: false) -%>
<li id="<%= dom_id(row) %>"
    class="wa-conversation <%= 'bg-neutral-lightest' if local_assigns[:selected] %> hover:bg-neutral-background">
  <%= link_to conversation_path(row.id),
              class: "flex items-center gap-3 px-4 py-2.5 no-underline text-inherit border-b border-neutral-lightest",
              data: { turbo_frame: "_top" } do %>
    <div class="flex h-11 w-11 flex-none items-center justify-center rounded-full bg-gradient-to-br from-brand-primary-light to-brand-primary text-white font-semibold uppercase">
      <%= row.contact_display_initial %>
    </div>
    <div class="flex flex-1 flex-col gap-0.5 min-w-0">
      <div class="flex items-center justify-between gap-2">
        <span class="wa-conversation__name truncate text-base font-medium text-neutral-darkest">
          <%= row.contact_display_name %>
        </span>
        <% if row.last_message_at %>
          <span class="flex-none text-xs text-neutral-medium">
            <%= row.last_message_at.strftime("%H:%M") %>
          </span>
        <% end %>
      </div>
      <div class="flex items-center justify-between gap-2">
        <span class="wa-conversation__preview flex-1 truncate text-sm text-neutral-medium">
          <%= row.last_message_preview %>
        </span>
        <% if row.unread? %>
          <span class="inline-flex h-5 min-w-5 items-center justify-center rounded-full bg-brand-secondary px-1.5 text-xs font-semibold text-brand-secondary-darkest">
            <%= row.unread_count %>
          </span>
        <% end %>
      </div>
    </div>
  <% end %>
</li>
