<%# locals: (thread:, messages:) -%>
<%= turbo_stream_from "conversation_#{thread.id}" %>

<header class="wa-thread__header flex items-center gap-3.5 px-4 py-2 min-h-[60px] bg-neutral-background/90 backdrop-blur-sm border-b border-neutral-lightest">
  <div class="flex h-11 w-11 flex-none items-center justify-center rounded-full bg-gradient-to-br from-brand-primary-light to-brand-primary text-white font-semibold uppercase">
    <%= thread.contact_display_initial %>
  </div>
  <div class="flex flex-1 flex-col min-w-0">
    <strong class="text-base font-medium text-neutral-darkest"><%= thread.contact_display_name %></strong>
    <small class="text-[13px] text-neutral-medium"><%= thread.contact_phone %></small>
  </div>
  <div class="flex gap-1">
    <%= link_to contact_path(thread.contact_id),
                class: "inline-flex h-9 w-9 items-center justify-center rounded-full text-neutral-medium hover:bg-neutral-lightest hover:text-neutral-darkest transition",
                title: "Contact details",
                aria: { label: "Contact details" } do %>
      <svg viewBox="0 0 24 24" class="h-5 w-5"><circle cx="12" cy="8" r="4" fill="none" stroke="currentColor" stroke-width="2"/><path d="M4 22 Q4 14 12 14 Q20 14 20 22" fill="none" stroke="currentColor" stroke-width="2"/></svg>
    <% end %>
    <button type="button"
            class="inline-flex h-9 w-9 items-center justify-center rounded-full text-neutral-medium hover:bg-neutral-lightest hover:text-neutral-darkest transition"
            title="Search" aria-label="Search">
      <svg viewBox="0 0 24 24" class="h-5 w-5"><circle cx="11" cy="11" r="7" fill="none" stroke="currentColor" stroke-width="2"/><path d="M16 16l5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </button>
    <button type="button"
            class="inline-flex h-9 w-9 items-center justify-center rounded-full text-neutral-medium hover:bg-neutral-lightest hover:text-neutral-darkest transition"
            title="Menu" aria-label="Menu">
      <svg viewBox="0 0 24 24" class="h-5 w-5"><circle cx="5" cy="12" r="1.6" fill="currentColor"/><circle cx="12" cy="12" r="1.6" fill="currentColor"/><circle cx="19" cy="12" r="1.6" fill="currentColor"/></svg>
    </button>
  </div>
</header>

<div class="wa-scroll flex-1 overflow-y-auto px-[8%] py-4 scroll-smooth" data-controller="scroll-to-bottom">
  <ul id="messages" class="flex flex-col gap-1 m-0 p-0 list-none">
    <% messages.each do |message| %>
      <%= render "messages/message", message: message %>
    <% end %>
  </ul>
</div>

<footer class="px-4 py-2.5 bg-neutral-background border-t border-neutral-lightest">
  <%= form_with url: conversation_messages_path(thread.id),
                scope: :message,
                method: :post,
                data: { controller: "composer emoji-picker", action: "submit->composer#clearOnSubmit" },
                class: "wa-composer__form relative flex items-end gap-2.5" do |f| %>

    <button type="button"
            class="inline-flex h-9 w-9 items-center justify-center rounded-full text-neutral-medium hover:bg-neutral-lightest hover:text-neutral-darkest transition"
            title="Emoji" aria-label="Emoji"
            data-action="emoji-picker#toggle click@window->emoji-picker#hideOnOutside">
      <svg viewBox="0 0 24 24" class="h-5 w-5"><circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="1.8"/><circle cx="9" cy="10" r="1.2" fill="currentColor"/><circle cx="15" cy="10" r="1.2" fill="currentColor"/><path d="M8 14 Q12 18 16 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
    </button>

    <div class="wa-scroll hidden absolute bottom-[calc(100%+8px)] left-0 z-20 w-[min(380px,96%)] max-h-[340px] overflow-y-auto rounded-2xl bg-white p-3 shadow-level-3"
         data-emoji-picker-target="panel"></div>

    <%= f.text_area :body,
          placeholder: "Type a message",
          rows: 1,
          required: true,
          data: {
            composer_target: "input",
            emoji_picker_target: "input",
            action: "keydown->composer#maybeSubmit input->composer#autoresize"
          },
          class: "flex-1 resize-none min-h-[42px] max-h-[200px] rounded-lg border-0 bg-white px-4 py-2.5 text-[15px] leading-5 outline-none shadow-level-1" %>

    <button type="submit"
            class="inline-flex h-[42px] w-[42px] flex-none items-center justify-center rounded-full border-0 bg-brand-primary text-white transition hover:bg-brand-primary-dark cursor-pointer"
            title="Send" aria-label="Send">
      <svg viewBox="0 0 24 24" class="h-[22px] w-[22px]"><path d="M3 12 L21 4 L13 22 L11 13 Z" fill="currentColor"/></svg>
    </button>
  <% end %>
</footer>
